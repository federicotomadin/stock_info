# Backend server port
PORT=

# Optional: Finnhub API key for reliable company fundamentals
# Create one free at https://finnhub.io/
FINNHUB_API_KEY=

# Financial Modeling Prep — fundamentals tab (/api/fmp/fundamentals) and
# stock prices when Stooq fails and Yahoo returns HTTP 429 (rate limit).
# https://financialmodelingprep.com/developer/docs
#
# IMPORTANT: this key must live on the BACKEND host (Render), not only in GitHub Secrets.
# GitHub Actions only builds the static frontend; it does not run Express.
FMP_API_KEY=

# --- Technical analysis (AI narrative for /api/technical-analysis) ---
# Provider to use: gemini | claude | groq (default: gemini).
# If the chosen provider has no key, the server auto-falls-back to any other key available.
# If NO key is configured, the endpoint still returns indicators (SMA, RSI, supports/resistances)
# with `analysis: null` and an `analysisError` explaining how to enable the AI narrative.
AI_PROVIDER=gemini

# Gemini (free tier, recommended). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude (paid). https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# Groq (free tier, OpenAI-compatible API). https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Frontend (build estático / GitHub Pages) ---
# URL del backend en producción, sin barra final (ej. https://tu-api.onrender.com).
# En local déjalo vacío: Vite hace proxy de /api al servidor.
# VITE_API_ORIGIN=

# Solo al hacer `npm run build` para GitHub Pages: base del sitio (ej. /stock_info/).
# En local no hace falta.
# VITE_BASE_PATH=
