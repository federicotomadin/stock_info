# Backend server port
PORT=

# Optional: Finnhub API key for reliable company fundamentals
# Create one free at https://finnhub.io/
FINNHUB_API_KEY=

# Financial Modeling Prep — fundamentals tab (/api/fmp/fundamentals) and
# stock prices when Stooq fails and Yahoo returns HTTP 429 (rate limit).
# https://financialmodelingprep.com/developer/docs
FMP_API_KEY=

# --- Frontend (build estático / GitHub Pages) ---
# URL del backend en producción, sin barra final (ej. https://tu-api.onrender.com).
# En local déjalo vacío: Vite hace proxy de /api al servidor.
# VITE_API_ORIGIN=

# Solo al hacer `npm run build` para GitHub Pages: base del sitio (ej. /stock_info/).
# En local no hace falta.
# VITE_BASE_PATH=
